generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  USER
}

enum ModuleKey {
  AI_ASSISTANT
  CRM
  ERP
  MARKETPLACE_ANALYZER
  INTERNET_DIAGNOSTICS
  CLOUD_TOOLS
  BUSINESS_AUTOMATION
}

enum ModuleStatus {
  ACTIVE
  DISABLED
  COMING_SOON
}

enum AuditAction {
  AUTH_REGISTER
  AUTH_LOGIN
  AUTH_LOGOUT
  MODULE_ENABLED
  MODULE_DISABLED
  AI_CONVERSATION_CREATED
  ASSISTANT_CHAT
  SETTINGS_UPDATED
  PROJECT_CREATED
  USER_ROLE_UPDATED
  CRM_ENTITY_CREATED
  CRM_ENTITY_UPDATED
  CRM_ENTITY_DELETED
  CRM_LEAD_SCORED
  ERP_ENTITY_CREATED
  ERP_ENTITY_UPDATED
  MARKETPLACE_SEARCH_CREATED
  MARKETPLACE_ANALYSIS_CREATED
  MARKETPLACE_PRODUCT_VIEWED
  MARKETPLACE_COMPARE_CREATED
  DIAGNOSTICS_RUN
}

enum MarketplaceStatus {
  ACTIVE
  DISABLED
}

enum MarketplaceJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AIMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum CRMLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum CRMDealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CRMDealActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STAGE_CHANGE
  TASK
}

enum CRMTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum CRMTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String?
  passwordHash      String
  role              Role                 @default(USER)
  memberships       OrganizationMember[]
  conversations     AIConversation[]
  aiMessages        AIMessage[]
  aiUsageLogs       AIUsageLog[]
  assignedCompanies Company[]            @relation("CompanyAssignee")
  assignedContacts  Contact[]            @relation("ContactAssignee")
  assignedLeads     Lead[]               @relation("LeadAssignee")
  assignedDeals     Deal[]               @relation("DealAssignee")
  assignedTasks     Task[]               @relation("TaskAssignee")
  createdTasks      Task[]               @relation("TaskCreator")
  dealActivities    DealActivity[]       @relation("DealActivityActor")
  notes             Note[]               @relation("NoteAuthor")
  auditLogs         AuditLog[]           @relation("AuditActor")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([role])
}

model Organization {
  id                  String                @id @default(cuid())
  name                String
  slug                String                @unique
  domain              String?
  members             OrganizationMember[]
  projects            Project[]
  modules             OrganizationModule[]
  conversations       AIConversation[]
  aiMessages          AIMessage[]
  aiModelRoutes       AIModelRoute[]
  aiUsageLogs         AIUsageLog[]
  companies           Company[]
  contacts            Contact[]
  leads               Lead[]
  pipelines           Pipeline[]
  pipelineStages      PipelineStage[]
  deals               Deal[]
  dealActivities      DealActivity[]
  tasks               Task[]
  notes               Note[]
  erpProducts         ERPProduct[]
  erpInventory        ERPInventoryItem[]
  erpInvoices         ERPInvoice[]
  marketplaceSearches MarketplaceSearch[]
  marketplaceAnalyses MarketplaceAnalysis[]
  marketplaceProducts  MarketplaceProduct[]
  marketplaceSnapshots MarketplaceSnapshot[]
  marketplaceJobs      MarketplaceJob[]
  marketplaceCaches    MarketplaceCache[]
  marketplaceTrends    MarketplaceTrend[]
  auditLogs           AuditLog[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(USER)
  isDefault      Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model Project {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  key            String
  status         String           @default("active")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  AIConversation[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, status])
}

model ModuleDefinition {
  id                  String               @id @default(cuid())
  key                 ModuleKey            @unique
  name                String
  description         String
  category            String
  path                String
  isolatedPath        String
  defaultEnabled      Boolean              @default(false)
  requiredRole        Role                 @default(USER)
  status              ModuleStatus         @default(COMING_SOON)
  organizationModules OrganizationModule[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model OrganizationModule {
  id                 String           @id @default(cuid())
  organizationId     String
  moduleDefinitionId String
  status             ModuleStatus     @default(ACTIVE)
  config             Json?
  enabledAt          DateTime?
  disabledAt         DateTime?
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition @relation(fields: [moduleDefinitionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([organizationId, moduleDefinitionId])
  @@index([organizationId, status])
}

model AIConversation {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  userId         String
  routeId        String?
  providerId     String?
  title          String
  provider       String        @default("magz")
  model          String?
  messages       Json
  status         String        @default("open")
  toolType       String?
  isPinned       Boolean       @default(false)
  isFavorite     Boolean       @default(false)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  route          AIModelRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)
  providerRef    AIProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  aiMessages     AIMessage[]
  usageLogs      AIUsageLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, updatedAt])
  @@index([organizationId, isPinned, updatedAt])
  @@index([organizationId, isFavorite, updatedAt])
  @@index([organizationId, toolType, updatedAt])
  @@index([userId, updatedAt])
  @@index([routeId])
  @@index([providerId])
}

model AIProvider {
  id            String           @id @default(cuid())
  key           String           @unique
  name          String
  kind          String
  baseUrl       String?
  apiKeyEnv     String?
  isEnabled     Boolean          @default(true)
  metadata      Json?
  modelRoutes   AIModelRoute[]
  conversations AIConversation[]
  messages      AIMessage[]
  usageLogs     AIUsageLog[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([kind, isEnabled])
}

model AIModelRoute {
  id             String           @id @default(cuid())
  routeKey       String           @unique
  organizationId String?
  providerId     String
  label          String
  model          String
  description    String
  priority       Int              @default(100)
  isDefault      Boolean          @default(false)
  isEnabled      Boolean          @default(true)
  settings       Json?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       AIProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  conversations  AIConversation[]
  messages       AIMessage[]
  usageLogs      AIUsageLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, isEnabled])
  @@index([providerId])
  @@index([isDefault, priority])
}

model AIMessage {
  id              String         @id @default(cuid())
  conversationId  String
  organizationId  String
  userId          String?
  routeId         String?
  providerId      String?
  role            AIMessageRole
  content         String
  tokenCount      Int            @default(0)
  costEstimateUsd Decimal?       @db.Decimal(12, 6)
  metadata        Json?
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  route           AIModelRoute?  @relation(fields: [routeId], references: [id], onDelete: SetNull)
  provider        AIProvider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  usageLogs       AIUsageLog[]
  createdAt       DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([routeId])
  @@index([providerId])
}

model AIUsageLog {
  id               String         @id @default(cuid())
  organizationId   String
  userId           String
  conversationId   String
  messageId        String?
  routeId          String?
  providerId       String?
  providerKey      String
  model            String
  promptTokens     Int            @default(0)
  completionTokens Int            @default(0)
  totalTokens      Int            @default(0)
  costEstimateUsd  Decimal?       @db.Decimal(12, 6)
  latencyMs        Int?
  status           String         @default("ok")
  errorCode        String?
  metadata         Json?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message          AIMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  route            AIModelRoute?  @relation(fields: [routeId], references: [id], onDelete: SetNull)
  provider         AIProvider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([routeId])
  @@index([providerId])
  @@index([status])
}

model Company {
  id             String       @id @default(cuid())
  organizationId String
  assignedUserId String?
  name           String
  domain         String?
  website        String?
  industry       String?
  phone          String?
  region         String?
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?        @relation("CompanyAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  contacts       Contact[]
  leads          Lead[]
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([organizationId, name])
  @@index([assignedUserId])
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  companyId      String?
  assignedUserId String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  title          String?
  status         String       @default("active")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedUser   User?        @relation("ContactAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  leads          Lead[]
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([organizationId, email])
  @@index([companyId])
  @@index([assignedUserId])
}

model Lead {
  id             String        @id @default(cuid())
  organizationId String
  companyId      String?
  contactId      String?
  assignedUserId String?
  title          String
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  companyName    String?
  source         String?
  status         CRMLeadStatus @default(NEW)
  estimatedValue Decimal?      @db.Decimal(12, 2)
  currency       String        @default("USD")
  aiScore        Int?
  aiScoreReason  String?
  aiScoredAt     DateTime?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedUser   User?         @relation("LeadAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, aiScore])
  @@index([companyId])
  @@index([contactId])
  @@index([assignedUserId])
}

model Pipeline {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean         @default(false)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages         PipelineStage[]
  deals          Deal[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, isDefault, deletedAt])
}

model PipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  pipelineId     String
  name           String
  position       Int
  probability    Int          @default(0)
  color          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline       Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals          Deal[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([pipelineId, position])
  @@index([organizationId, deletedAt])
  @@index([pipelineId, position])
}

model Deal {
  id                String         @id @default(cuid())
  organizationId    String
  pipelineId        String
  stageId           String
  companyId         String?
  contactId         String?
  leadId            String?
  assignedUserId    String?
  title             String
  description       String?
  value             Decimal        @default(0) @db.Decimal(12, 2)
  currency          String         @default("USD")
  status            CRMDealStatus  @default(OPEN)
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostAt            DateTime?
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline          Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage             PipelineStage  @relation(fields: [stageId], references: [id], onDelete: Restrict)
  company           Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact           Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead              Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUser      User?          @relation("DealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activities        DealActivity[]
  tasks             Task[]
  notes             Note[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([pipelineId, stageId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([assignedUserId])
}

model DealActivity {
  id             String              @id @default(cuid())
  organizationId String
  dealId         String
  userId         String?
  type           CRMDealActivityType @default(NOTE)
  title          String
  content        String?
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal           Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user           User?               @relation("DealActivityActor", fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@index([organizationId, createdAt])
  @@index([dealId, createdAt])
  @@index([userId])
}

model Task {
  id             String          @id @default(cuid())
  organizationId String
  assignedUserId String?
  createdById    String?
  companyId      String?
  contactId      String?
  leadId         String?
  dealId         String?
  title          String
  description    String?
  status         CRMTaskStatus   @default(TODO)
  priority       CRMTaskPriority @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?           @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal           Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([assignedUserId])
  @@index([createdById])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  authorId       String?
  companyId      String?
  contactId      String?
  leadId         String?
  dealId         String?
  content        String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User?        @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal           Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([authorId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
}

model ERPProduct {
  id             String             @id @default(cuid())
  organizationId String
  sku            String
  name           String
  category       String?
  unitPrice      Decimal            @default(0) @db.Decimal(12, 2)
  currency       String             @default("USD")
  status         String             @default("active")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItems ERPInventoryItem[]
  invoiceItems   ERPInvoiceItem[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, sku])
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, name])
}

model ERPInventoryItem {
  id             String       @id @default(cuid())
  organizationId String
  productId      String
  location       String       @default("Main warehouse")
  quantity       Int          @default(0)
  reorderPoint   Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        ERPProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, productId, location])
  @@index([organizationId, deletedAt])
  @@index([productId])
}

model ERPInvoice {
  id             String           @id @default(cuid())
  organizationId String
  invoiceNumber  String
  customerName   String
  customerEmail  String?
  currency       String           @default("USD")
  subtotal       Decimal          @default(0) @db.Decimal(12, 2)
  tax            Decimal          @default(0) @db.Decimal(12, 2)
  total          Decimal          @default(0) @db.Decimal(12, 2)
  status         String           @default("draft")
  notes          String?
  issuedAt       DateTime         @default(now())
  dueAt          DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          ERPInvoiceItem[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, issuedAt])
}

model ERPInvoiceItem {
  id          String      @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Int         @default(1)
  unitPrice   Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @default(0) @db.Decimal(12, 2)
  invoice     ERPInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     ERPProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([invoiceId])
  @@index([productId])
}

model Marketplace {
  id             String                @id @default(cuid())
  key            String                @unique
  name           String
  country        String                @default("TJ")
  baseUrl        String
  searchUrl      String?
  status         MarketplaceStatus     @default(ACTIVE)
  adapterKey     String
  config         Json?
  products       MarketplaceProduct[]
  categories     MarketplaceCategory[]
  sellers        MarketplaceSeller[]
  snapshots      MarketplaceSnapshot[]
  jobs           MarketplaceJob[]
  caches         MarketplaceCache[]
  trends         MarketplaceTrend[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([country, status])
  @@index([adapterKey])
}

model MarketplaceCategory {
  id             String                @id @default(cuid())
  marketplaceId  String
  parentId       String?
  externalId     String?
  name           String
  slug           String?
  url            String?
  marketplace    Marketplace           @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  parent         MarketplaceCategory?  @relation("MarketplaceCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       MarketplaceCategory[] @relation("MarketplaceCategoryTree")
  products       MarketplaceProduct[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([marketplaceId, externalId])
  @@index([marketplaceId, name])
  @@index([parentId])
}

model MarketplaceSeller {
  id             String               @id @default(cuid())
  marketplaceId  String
  externalId     String?
  name           String
  profileUrl     String?
  rating         Decimal?             @db.Decimal(5, 2)
  marketplace    Marketplace          @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  products       MarketplaceProduct[]
  snapshots      MarketplaceSnapshot[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([marketplaceId, externalId])
  @@unique([marketplaceId, name])
  @@index([marketplaceId, rating])
}

model MarketplaceProduct {
  id                String                    @id @default(cuid())
  organizationId    String
  marketplaceId     String
  categoryId        String?
  sellerId          String?
  externalId        String?
  title             String
  normalizedTitle   String
  description       String?
  url               String
  currency          String                    @default("TJS")
  currentPrice      Decimal?                  @db.Decimal(12, 2)
  originalPrice     Decimal?                  @db.Decimal(12, 2)
  availability      String?
  rating            Decimal?                  @db.Decimal(5, 2)
  reviewCount       Int?
  popularityScore   Decimal?                  @db.Decimal(8, 2)
  lastSeenAt        DateTime                  @default(now())
  firstSeenAt       DateTime                  @default(now())
  metadata          Json?
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace       Marketplace               @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  category          MarketplaceCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  seller            MarketplaceSeller?        @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  images            MarketplaceImage[]
  snapshots         MarketplaceSnapshot[]
  priceHistory      MarketplacePriceHistory[]
  analyses          MarketplaceAnalysis[]
  trends            MarketplaceTrend[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([organizationId, marketplaceId, externalId])
  @@unique([organizationId, marketplaceId, url])
  @@index([organizationId, normalizedTitle])
  @@index([organizationId, currentPrice])
  @@index([marketplaceId, lastSeenAt])
  @@index([categoryId])
  @@index([sellerId])
}

model MarketplaceImage {
  id          String             @id @default(cuid())
  productId   String
  url         String
  alt         String?
  position    Int                @default(0)
  product     MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@unique([productId, url])
  @@index([productId, position])
}

model MarketplaceSnapshot {
  id             String              @id @default(cuid())
  organizationId String
  marketplaceId  String
  productId      String
  sellerId       String?
  price          Decimal?            @db.Decimal(12, 2)
  currency       String              @default("TJS")
  availability   String?
  rating         Decimal?            @db.Decimal(5, 2)
  reviewCount    Int?
  popularityRaw  String?
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace    Marketplace         @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  product        MarketplaceProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller         MarketplaceSeller?  @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@index([organizationId, createdAt])
  @@index([productId, createdAt])
  @@index([marketplaceId, createdAt])
}

model MarketplacePriceHistory {
  id          String             @id @default(cuid())
  productId   String
  price       Decimal            @db.Decimal(12, 2)
  currency    String             @default("TJS")
  source      String             @default("snapshot")
  product     MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  capturedAt  DateTime           @default(now())

  @@index([productId, capturedAt])
}

model MarketplaceSearch {
  id             String                @id @default(cuid())
  organizationId String
  query          String
  marketplace    String?
  source         String                @default("manual")
  results        Json
  status         String                @default("completed")
  resultCount    Int                   @default(0)
  minPrice       Decimal?              @db.Decimal(12, 2)
  maxPrice       Decimal?              @db.Decimal(12, 2)
  averagePrice   Decimal?              @db.Decimal(12, 2)
  metadata       Json?
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analyses       MarketplaceAnalysis[]
  createdAt      DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, query])
}

model MarketplaceAnalysis {
  id             String             @id @default(cuid())
  organizationId String
  searchId       String?
  productId      String?
  productName    String
  marketplace    String?
  input          Json
  summary        String
  recommendation String
  score          Int                @default(50)
  pros           Json?
  cons           Json?
  demand         String?
  targetAudience String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  search         MarketplaceSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  product        MarketplaceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())

  @@index([organizationId, createdAt])
  @@index([searchId])
  @@index([productId])
  @@index([score])
}

model MarketplaceJob {
  id             String               @id @default(cuid())
  organizationId String
  marketplaceId  String?
  type           String
  status         MarketplaceJobStatus  @default(QUEUED)
  payload        Json
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace    Marketplace?         @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([marketplaceId, createdAt])
}

model MarketplaceCache {
  id             String       @id @default(cuid())
  organizationId String
  marketplaceId  String?
  cacheKey       String
  value          Json
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace    Marketplace? @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, cacheKey])
  @@index([expiresAt])
  @@index([marketplaceId])
}

model MarketplaceTrend {
  id             String              @id @default(cuid())
  organizationId String
  marketplaceId  String?
  productId      String?
  category       String?
  keyword        String
  score          Decimal             @default(0) @db.Decimal(8, 2)
  signal         String?
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace    Marketplace?        @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  product        MarketplaceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  capturedAt     DateTime            @default(now())

  @@index([organizationId, capturedAt])
  @@index([marketplaceId, capturedAt])
  @@index([productId])
  @@index([keyword])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
}
