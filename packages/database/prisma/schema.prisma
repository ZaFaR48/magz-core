generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  USER
}

enum ModuleKey {
  AI_ASSISTANT
  CRM
  ERP
  MARKETPLACE_ANALYZER
  INTERNET_DIAGNOSTICS
  CLOUD_TOOLS
  BUSINESS_AUTOMATION
}

enum ModuleStatus {
  ACTIVE
  DISABLED
  COMING_SOON
}

enum AuditAction {
  AUTH_REGISTER
  AUTH_LOGIN
  AUTH_LOGOUT
  MODULE_ENABLED
  MODULE_DISABLED
  AI_CONVERSATION_CREATED
  ASSISTANT_CHAT
  SETTINGS_UPDATED
  PROJECT_CREATED
  USER_ROLE_UPDATED
  CRM_ENTITY_CREATED
  CRM_ENTITY_UPDATED
  CRM_ENTITY_DELETED
  CRM_LEAD_SCORED
}

enum AIMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum CRMLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum CRMDealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CRMDealActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STAGE_CHANGE
  TASK
}

enum CRMTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum CRMTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String?
  passwordHash      String
  role              Role                 @default(USER)
  memberships       OrganizationMember[]
  conversations     AIConversation[]
  aiMessages        AIMessage[]
  aiUsageLogs       AIUsageLog[]
  assignedCompanies Company[]            @relation("CompanyAssignee")
  assignedContacts  Contact[]            @relation("ContactAssignee")
  assignedLeads     Lead[]               @relation("LeadAssignee")
  assignedDeals     Deal[]               @relation("DealAssignee")
  assignedTasks     Task[]               @relation("TaskAssignee")
  createdTasks      Task[]               @relation("TaskCreator")
  dealActivities    DealActivity[]       @relation("DealActivityActor")
  notes             Note[]               @relation("NoteAuthor")
  auditLogs         AuditLog[]           @relation("AuditActor")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([role])
}

model Organization {
  id             String               @id @default(cuid())
  name           String
  slug           String               @unique
  domain         String?
  members        OrganizationMember[]
  projects       Project[]
  modules        OrganizationModule[]
  conversations  AIConversation[]
  aiMessages     AIMessage[]
  aiModelRoutes  AIModelRoute[]
  aiUsageLogs    AIUsageLog[]
  companies      Company[]
  contacts       Contact[]
  leads          Lead[]
  pipelines      Pipeline[]
  pipelineStages PipelineStage[]
  deals          Deal[]
  dealActivities DealActivity[]
  tasks          Task[]
  notes          Note[]
  auditLogs      AuditLog[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(USER)
  isDefault      Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model Project {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  key            String
  status         String           @default("active")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  AIConversation[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, status])
}

model ModuleDefinition {
  id                  String               @id @default(cuid())
  key                 ModuleKey            @unique
  name                String
  description         String
  category            String
  path                String
  isolatedPath        String
  defaultEnabled      Boolean              @default(false)
  requiredRole        Role                 @default(USER)
  status              ModuleStatus         @default(COMING_SOON)
  organizationModules OrganizationModule[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model OrganizationModule {
  id                 String           @id @default(cuid())
  organizationId     String
  moduleDefinitionId String
  status             ModuleStatus     @default(ACTIVE)
  config             Json?
  enabledAt          DateTime?
  disabledAt         DateTime?
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition @relation(fields: [moduleDefinitionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([organizationId, moduleDefinitionId])
  @@index([organizationId, status])
}

model AIConversation {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  userId         String
  routeId        String?
  providerId     String?
  title          String
  provider       String        @default("magz")
  model          String?
  messages       Json
  status         String        @default("open")
  toolType       String?
  isPinned       Boolean       @default(false)
  isFavorite     Boolean       @default(false)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  route          AIModelRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)
  providerRef    AIProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  aiMessages     AIMessage[]
  usageLogs      AIUsageLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, updatedAt])
  @@index([organizationId, isPinned, updatedAt])
  @@index([organizationId, isFavorite, updatedAt])
  @@index([organizationId, toolType, updatedAt])
  @@index([userId, updatedAt])
  @@index([routeId])
  @@index([providerId])
}

model AIProvider {
  id            String           @id @default(cuid())
  key           String           @unique
  name          String
  kind          String
  baseUrl       String?
  apiKeyEnv     String?
  isEnabled     Boolean          @default(true)
  metadata      Json?
  modelRoutes   AIModelRoute[]
  conversations AIConversation[]
  messages      AIMessage[]
  usageLogs     AIUsageLog[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([kind, isEnabled])
}

model AIModelRoute {
  id             String           @id @default(cuid())
  routeKey       String           @unique
  organizationId String?
  providerId     String
  label          String
  model          String
  description    String
  priority       Int              @default(100)
  isDefault      Boolean          @default(false)
  isEnabled      Boolean          @default(true)
  settings       Json?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       AIProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  conversations  AIConversation[]
  messages       AIMessage[]
  usageLogs      AIUsageLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, isEnabled])
  @@index([providerId])
  @@index([isDefault, priority])
}

model AIMessage {
  id              String         @id @default(cuid())
  conversationId  String
  organizationId  String
  userId          String?
  routeId         String?
  providerId      String?
  role            AIMessageRole
  content         String
  tokenCount      Int            @default(0)
  costEstimateUsd Decimal?       @db.Decimal(12, 6)
  metadata        Json?
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  route           AIModelRoute?  @relation(fields: [routeId], references: [id], onDelete: SetNull)
  provider        AIProvider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  usageLogs       AIUsageLog[]
  createdAt       DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([routeId])
  @@index([providerId])
}

model AIUsageLog {
  id               String         @id @default(cuid())
  organizationId   String
  userId           String
  conversationId   String
  messageId        String?
  routeId          String?
  providerId       String?
  providerKey      String
  model            String
  promptTokens     Int            @default(0)
  completionTokens Int            @default(0)
  totalTokens      Int            @default(0)
  costEstimateUsd  Decimal?       @db.Decimal(12, 6)
  latencyMs        Int?
  status           String         @default("ok")
  errorCode        String?
  metadata         Json?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message          AIMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  route            AIModelRoute?  @relation(fields: [routeId], references: [id], onDelete: SetNull)
  provider         AIProvider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([routeId])
  @@index([providerId])
  @@index([status])
}

model Company {
  id             String       @id @default(cuid())
  organizationId String
  assignedUserId String?
  name           String
  domain         String?
  website        String?
  industry       String?
  phone          String?
  region         String?
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?        @relation("CompanyAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  contacts       Contact[]
  leads          Lead[]
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([organizationId, name])
  @@index([assignedUserId])
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  companyId      String?
  assignedUserId String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  title          String?
  status         String       @default("active")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedUser   User?        @relation("ContactAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  leads          Lead[]
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([organizationId, email])
  @@index([companyId])
  @@index([assignedUserId])
}

model Lead {
  id             String        @id @default(cuid())
  organizationId String
  companyId      String?
  contactId      String?
  assignedUserId String?
  title          String
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  companyName    String?
  source         String?
  status         CRMLeadStatus @default(NEW)
  estimatedValue Decimal?      @db.Decimal(12, 2)
  currency       String        @default("USD")
  aiScore        Int?
  aiScoreReason  String?
  aiScoredAt     DateTime?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedUser   User?         @relation("LeadAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  deals          Deal[]
  tasks          Task[]
  notes          Note[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, aiScore])
  @@index([companyId])
  @@index([contactId])
  @@index([assignedUserId])
}

model Pipeline {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean         @default(false)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages         PipelineStage[]
  deals          Deal[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, isDefault, deletedAt])
}

model PipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  pipelineId     String
  name           String
  position       Int
  probability    Int          @default(0)
  color          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline       Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals          Deal[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([pipelineId, position])
  @@index([organizationId, deletedAt])
  @@index([pipelineId, position])
}

model Deal {
  id                String         @id @default(cuid())
  organizationId    String
  pipelineId        String
  stageId           String
  companyId         String?
  contactId         String?
  leadId            String?
  assignedUserId    String?
  title             String
  description       String?
  value             Decimal        @default(0) @db.Decimal(12, 2)
  currency          String         @default("USD")
  status            CRMDealStatus  @default(OPEN)
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostAt            DateTime?
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline          Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage             PipelineStage  @relation(fields: [stageId], references: [id], onDelete: Restrict)
  company           Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact           Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead              Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUser      User?          @relation("DealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activities        DealActivity[]
  tasks             Task[]
  notes             Note[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([pipelineId, stageId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([assignedUserId])
}

model DealActivity {
  id             String              @id @default(cuid())
  organizationId String
  dealId         String
  userId         String?
  type           CRMDealActivityType @default(NOTE)
  title          String
  content        String?
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal           Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user           User?               @relation("DealActivityActor", fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@index([organizationId, createdAt])
  @@index([dealId, createdAt])
  @@index([userId])
}

model Task {
  id             String          @id @default(cuid())
  organizationId String
  assignedUserId String?
  createdById    String?
  companyId      String?
  contactId      String?
  leadId         String?
  dealId         String?
  title          String
  description    String?
  status         CRMTaskStatus   @default(TODO)
  priority       CRMTaskPriority @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?           @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal           Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, status, deletedAt])
  @@index([assignedUserId])
  @@index([createdById])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  authorId       String?
  companyId      String?
  contactId      String?
  leadId         String?
  dealId         String?
  content        String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User?        @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal           Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId, deletedAt])
  @@index([authorId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
}
